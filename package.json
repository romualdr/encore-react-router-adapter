{
  "name": "encore-react-router-adapter",
  "version": "0.1.2",
  "description": "Encore.ts connector for React Router v7. Vite middleware mode + HMR in dev, compiled SSR build with static asset serving in production.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/romualdr/encore-react-router-adapter.git"
  },
  "bugs": {
    "url": "https://github.com/romualdr/encore-react-router-adapter/issues"
  },
  "homepage": "https://github.com/romualdr/encore-react-router-adapter#readme",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "encore",
    "encore.ts",
    "react-router",
    "ssr",
    "vite"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "peerDependencies": {
    "@react-router/dev": "^7.0.0",
    "encore.dev": ">=1.57.0",
    "react-router": "^7.0.0",
    "vite": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "@react-router/dev": {
      "optional": true
    },
    "vite": {
      "optional": true
    }
  },
  "dependencies": {
    "@mjackson/node-fetch-server": "^0.7.0",
    "sirv": "^3.0.2"
  },
  "devDependencies": {
    "@react-router/dev": "^7.14.0",
    "@types/node": "^25.6.2",
    "encore.dev": "^1.57.0",
    "react-router": "^7.14.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.11"
  }
}
